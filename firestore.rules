rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Secure: Checks for existence of user's UID in a protected Admins collection.
      return isAuthenticated() && exists(/databases/$(database)/documents/Admins/$(request.auth.uid));
    }
    
    function isOwner(canteenId) {
      // Secure: Fetches the owner doc and checks if the canteen_id matches.
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/Owners/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/Owners/$(request.auth.uid)).data.canteen_id == canteenId;
    }

    function isRider() {
      // Secure: Checks if the user is in the Riders collection and is active.
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/Riders/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/Riders/$(request.auth.uid)).data.isActive == true;
    }
    
    // Users can read/write their own document. Admins can read/list all.
    match /Users/{userId} {
      allow read: if isUser(userId) || isAdmin();
      allow write: if isUser(userId) || isAdmin();
    }

    // Riders collection
    match /Riders/{riderId} {
      // Allows any authenticated user to see rider details (for order tracking).
      allow get: if isAuthenticated();
      // Only admins or the rider themselves can list or modify.
      allow list, create, update: if isAdmin() || isUser(riderId);
    }
    
    // Admins collection
    match /Admins/{adminId} {
      // Allows user to check if they are an admin during login.
      allow get: if isUser(adminId);
      // Only admins can list or write admin documents.
      allow list, write: if isAdmin();
    }
    
    // Owners collection
    match /Owners/{ownerId} {
      // Allows user to check their own application status.
      allow get: if isUser(ownerId) || isAdmin();
      // A user can create their own owner application.
      allow create: if isUser(ownerId);
      // Only admins can list or update owner documents.
      allow list, update: if isAdmin();
    }
    
    // Canteens collection
    match /Canteens/{canteenId} {
      // Any logged-in user can view canteen details.
      allow read: if isAuthenticated();
      // Only the owner or an admin can modify a canteen.
      allow write: if isAdmin() || isOwner(canteenId);
      
      // MenuItems subcollection
      match /MenuItems/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() || isOwner(canteenId);
      }
      
      // Inventory subcollection
      match /Inventory/{inventoryId} {
        allow read, write: if isAdmin() || isOwner(canteenId);
      }
      
      // Counters subcollection - FIXED
      match /Counters/{dateString} {
        // CRITICAL FIX: Only the owner or an admin can read or write to counters.
        allow read, write: if isAdmin() || isOwner(canteenId);
      }
    }
    
    // Orders collection
    match /Orders/{orderId} {
      // Admins and Riders can list orders.
      allow list: if isAdmin() || isRider();
      allow get: if isAuthenticated() && 
                    (request.auth.uid == resource.data.userId || 
                     isAdmin() || 
                     isRider() ||
                     isOwner(resource.data.canteenId));
      // A user can only create an order for themselves.
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      // An owner, admin, or rider can update an order.
      // Riders can only update status and riderId.
      allow update: if isAdmin() || 
                      isOwner(resource.data.canteenId) || 
                      (isRider() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'riderId', 'updatedAt']));
      // Only admins can delete orders.
      allow delete: if isAdmin();
    }
  }
}
